# Base URL del backend.
# Puede configurarse con o sin /api porque el frontend normaliza la ruta.
# Recomendado: usar el origen sin /api.
# Ejemplo recomendado para Vercel + Render: VITE_API_BASE_URL=https://cognia-api.onrender.com
# Ejemplo recomendado para dominio propio con proxy /api: VITE_API_BASE_URL=/api
# Ejemplo tambien valido: VITE_API_BASE_URL=https://www.cognia.lat/api
#
# Importante:
# En Vite, las variables VITE_* se resuelven en tiempo de desarrollo/build.
# Si cambias .env, debes reiniciar `npm run dev` o reconstruir la app para produccion.
VITE_API_BASE_URL=https://cognia-api.onrender.com
VITE_COGNIA_ENCRYPTED_TRANSPORT=true
VITE_COGNIA_REQUIRE_ENCRYPTED_SENSITIVE_PAYLOADS=true
VITE_DEBUG_API_CLIENT=false

VITE_DEV_AUTH_BYPASS=true
VITE_DEV_ROLE=guardian
